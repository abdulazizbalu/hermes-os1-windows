{
  "name": "luma-desktop",
  "version": "0.1.0",
  "description": "Local AI workspace for Windows powered by Gemma.",
  "author": "Abdulaziz",
  "license": "MIT",
  "private": false,
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:win": "npm run build && electron-builder --win nsis",
    "lint": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@swc/core": "^1.13.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.abdulazizbalu.lumadesktop",
    "productName": "Luma Desktop",
    "directories": {
      "buildResources": "buildResources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "buildResources/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "buildResources/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Luma-Desktop-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Luma Desktop"
    }
  }
}
